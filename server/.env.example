# ====================================
# 应用配置
# ====================================

APP_NAME=x-JingWei
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_LOCALE=zh_CN

# ====================================
# 服务器配置
# ====================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=true

# ====================================
# 日志配置
# ====================================

LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=7 days
LOG_COMPRESSION=zip
LOG_CONSOLE_OUTPUT=true

# ====================================
# CORS配置
# ====================================

CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ====================================
# 限流配置
# ====================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ====================================
# 数据库配置
# ====================================

DATABASE_ENABLED=true
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/jingwei?charset=utf8mb4
ASYNC_DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/jingwei?charset=utf8mb4
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# ====================================
# Redis配置
# ====================================

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_MAX_CONNECTIONS=50
REDIS_DECODE_RESPONSES=true
REDIS_SOCKET_TIMEOUT=5

# ====================================
# 安全配置
# ====================================

SECRET_KEY=your-secret-key-change-this-in-production
SECURITY_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====================================
# DeepSeek Model Configuration
# ====================================

# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DEEPSEEK_MODEL_NAME=deepseek-chat

# ====================================
# Doubao Model Configuration
# ====================================

# DOUBAO_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL_NAME=ep-xxxxxxxxxxxxxx

# ====================================
# Alibaba Cloud Tongyi Qianwen Model Configuration
# ====================================

# ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# ALIYUN_MODEL_NAME=qwen-plus

# ====================================
# 向量数据库配置
# ====================================

VECTOR_STORE_ENABLED=false
VECTOR_STORE_TYPE=chromadb
VECTOR_STORE_PERSIST_DIRECTORY=./data/vector_store
VECTOR_STORE_COLLECTION_NAME=x-jingwei
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ====================================
# 文档处理配置
# ====================================

DOCUMENT_MAX_FILE_SIZE=10485760
DOCUMENT_CHUNK_SIZE=500
DOCUMENT_CHUNK_OVERLAP=50

# ====================================
# LLM配置
# ====================================

LLM_DEFAULT_PROVIDER=deepseek
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# 结构化输出模式
STRUCTURED=False

# ====================================
# 外部服务 API 配置
# ====================================

# 高德地图 API 配置（天气查询）
# AMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====================================
# LangSmith 配置
# ====================================

# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxxxxxx
# LANGSMITH_API_BASE=https://api.langsmith.com/v1

# ====================================
# MCP 服务器配置
# ====================================

# WEATHER_MCP_BASE_URL=http://localhost:8000
# WEATHER_MCP_PATH=/mcp
# WEATHER_MCP_MODE=http

# MCP tools are disabled by default to avoid probing a local server on startup.
MCP_ENABLED=false

# ====================================
# 文本转 SQL 配置
# ====================================

TEXT_TO_SQL_MAX_ROWS=100
TEXT_TO_SQL_QUERY_TIMEOUT=30
